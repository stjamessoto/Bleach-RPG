# Copy this file to .env and fill in your key.
# Get a FREE Gemini key (no credit card required) at:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=your-free-gemini-key-here

# Optional overrides
# gemini-2.5-flash = free tier workhorse (~15 req/min, ~1,500 req/day)
# gemini-2.5-flash-lite = higher RPM if you want faster bursts
MODEL=gemini-2.5-flash
PORT=8787
