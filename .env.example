# Copy this file to .env and fill in your key.
# Get a FREE Gemini key (no credit card required) at:
#   https://aistudio.google.com/apikey
GEMINI_API_KEY=your-free-gemini-key-here

# Optional overrides
# gemini-flash-latest = an alias Google keeps pointed at their current
#   recommended free-tier flash model, so it won't 404 when a dated model
#   (like gemini-2.5-flash) gets retired. Currently resolves to gemini-3.5-flash.
# gemini-flash-lite-latest = lighter/faster alias if you want higher RPM
MODEL=gemini-flash-latest
PORT=8787
